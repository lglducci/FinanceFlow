        "query": " \n \nselect t.fatura_id, c.nome, c.bandeira, c.numero, limite_total, t.data_compra,    fechamento_dia,  vencimento_dia, nomecartao,t.valor ,t.descricao , t.parcela_num, t.parcela_total ,t.data_parcela, f.mes_referencia\n from   cartoes_faturas as f \n  inner join  cartoes as c\n  on c.id = f.cartao_id \n  and c.empresa_id = f.empresa_id \n  inner join  cartoes_transacoes as t on  t.empresa_id  = t.empresa_id and t.fatura_id = f.id\n  where f.empresa_id = {{ $json.id_empresa }}\n and  f.id = {{ $json.id }} \n  order by f.mes_referencia ,t.data_parcela asc",
